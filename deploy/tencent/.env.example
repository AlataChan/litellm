# ========================================================================
# 腾讯云部署环境变量模板（.env pool）
#
# 用法：
#   1. 首次 bootstrap.sh 会把本文件复制成 /opt/litellm/.env（权限 0600）
#   2. 在 /opt/litellm/.env 里填入需要用到的 provider 的真实 key
#   3. 没填 / 留空的 key 不影响启动；只要 litellm.config.yaml 里没用到就行
#
# 新增 provider 的流程（以后 99% 情况不用改本文件）：
#   a) 在 deploy/tencent/litellm.config.yaml 里加 model_list 条目
#   b) 在服务器 /opt/litellm/.env 里填好对应 *_API_KEY
#   c) git push origin main 触发自动部署
#
# 本模板已覆盖主流 provider。冷门 provider 再按需追加。
# ========================================================================


# ==================== 核心（必填）====================

# LiteLLM 签发/校验 token 的主密钥（生成：openssl rand -hex 32）
LITELLM_MASTER_KEY=sk-CHANGE_ME_TO_RANDOM_STRING

# 加密数据库中敏感字段（团队/用户 API Key 等）
LITELLM_SALT_KEY=CHANGE_ME_TO_ANOTHER_RANDOM_STRING

# Postgres 容器密码
POSTGRES_PASSWORD=CHANGE_ME_TO_DB_PASSWORD

# 管理后台账号
UI_USERNAME=admin
UI_PASSWORD=CHANGE_ME


# ==================== 国内主流（中文场景常用）====================

# DeepSeek（本项目首选，当前对接 V4：deepseek-v4-flash / deepseek-v4-pro）
# 申请 key：https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=
# 可选，默认 https://api.deepseek.com；若使用 Anthropic 兼容端点则填 https://api.deepseek.com/anthropic
DEEPSEEK_BASE_URL=

# 通义千问 / DashScope（阿里云）
DASHSCOPE_API_KEY=

# 智谱 GLM（bigmodel.cn）
ZHIPUAI_API_KEY=

# 月之暗面 Moonshot / Kimi
# API 文档：https://platform.kimi.com/docs
MOONSHOT_API_KEY=
# 可选，默认 https://api.moonshot.cn/v1
MOONSHOT_BASE_URL=https://api.moonshot.cn/v1

# 火山引擎 / 豆包（字节）
VOLCENGINE_API_KEY=

# MiniMax
MINIMAX_API_KEY=

# 百度千帆
BAIDU_API_KEY=
BAIDU_SECRET_KEY=


# ==================== 国际主流 ====================

# OpenAI
OPENAI_API_KEY=
OPENAI_BASE_URL=

# Anthropic（Claude）
ANTHROPIC_API_KEY=

# Google Gemini
GEMINI_API_KEY=

# Google Vertex AI（企业，使用服务账号 JSON 文件）
# 先把 JSON 放到服务器 /opt/litellm/credentials/vertex.json，再 volume 挂载进容器
GOOGLE_APPLICATION_CREDENTIALS=

# Mistral
MISTRAL_API_KEY=

# Groq（超快 LPU 推理）
GROQ_API_KEY=

# xAI Grok
XAI_API_KEY=

# Cohere
COHERE_API_KEY=

# OpenRouter（聚合网关）
OPENROUTER_API_KEY=

# Together AI
TOGETHERAI_API_KEY=

# Perplexity
PERPLEXITYAI_API_KEY=

# Replicate
REPLICATE_API_KEY=


# ==================== Azure / AWS（企业云）====================

# Azure OpenAI
AZURE_API_KEY=
AZURE_API_BASE=
AZURE_API_VERSION=

# AWS Bedrock
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION_NAME=


# ==================== 观测 / 日志（可选）====================

# Langfuse
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=

# Helicone
HELICONE_API_KEY=


# ==================== 其它占位（按需启用）====================

# Novita AI
NOVITA_API_KEY=

# Infinity
INFINITY_API_KEY=
