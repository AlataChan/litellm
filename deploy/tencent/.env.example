# 腾讯云部署环境变量模板
# 使用方式：首次在服务器上执行 bootstrap.sh 会从这里复制一份到 /opt/litellm/.env，之后手动编辑填值
# 切记：本文件只存模板，真正的秘钥不要提交到仓库

# === LiteLLM 核心 ===
# 强随机字符串，作为签发/校验 token 的主密钥（示例：openssl rand -hex 32）
LITELLM_MASTER_KEY=sk-CHANGE_ME_TO_RANDOM_STRING

# 用于加密数据库中敏感字段（团队/用户 API Key 等），生产必须设
LITELLM_SALT_KEY=CHANGE_ME_TO_ANOTHER_RANDOM_STRING

# === Postgres ===
POSTGRES_PASSWORD=CHANGE_ME_TO_DB_PASSWORD

# === DeepSeek ===
DEEPSEEK_API_KEY=sk-YOUR_DEEPSEEK_API_KEY

# === 管理后台（可选，建议生产都设）===
UI_USERNAME=admin
UI_PASSWORD=CHANGE_ME
